<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.effect.*?>

<BorderPane fx:id="root" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.timeclock.ClockWiseController"
            style="-fx-background-color: linear-gradient(to bottom, #f8fafc, #e2e8f0);">

    <!-- ===== TOP NAVBAR ===== -->
    <top>
        <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
            <padding>
                <Insets top="15" bottom="15" left="25" right="25"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <ImageView fitHeight="36" fitWidth="36" fx:id="logo" />
                <Label text="ClockWise" style="-fx-text-fill: #1e293b; -fx-font-size: 24px; -fx-font-weight: bold;"/>
            </HBox>
            <Pane HBox.hgrow="ALWAYS"/> <!-- Spacer -->
            <Button fx:id="logoutBtn" text="Logout" 
                   style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-weight: 600; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 8 16;"/>
        </HBox>
    </top>

    <!-- ===== CENTER MAIN CONTENT ===== -->
    <center>
        <VBox alignment="CENTER" spacing="40" style="-fx-padding: 40;">
            <!-- Current Time Display -->
            <VBox alignment="CENTER" spacing="8">
                <Label text="CURRENT TIME" style="-fx-text-fill: #64748b; -fx-font-size: 14px; -fx-font-weight: 600; -fx-letter-spacing: 1px;"/>
                <Label fx:id="timeLabel" text="12:45:32 PM" 
                       style="-fx-text-fill: #1e293b; -fx-font-size: 64px; -fx-font-weight: 300; -fx-font-family: 'System';"/>
                <Label fx:id="dateLabel" text="Monday, March 17, 2025" 
                       style="-fx-text-fill: #475569; -fx-font-size: 16px; -fx-font-weight: 500;"/>
            </VBox>

            <!-- Action Buttons -->
            <VBox alignment="CENTER" spacing="15">
                <HBox alignment="CENTER" spacing="16">
                    <Button fx:id="clockInBtn" text="CLOCK IN" 
                           style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 24; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(16, 185, 129, 0.3), 10, 0, 0, 4);"/>
                    <Button fx:id="clockOutBtn" text="CLOCK OUT" 
                           style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 24; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(239, 68, 68, 0.3), 10, 0, 0, 4);"/>
                    <Button fx:id="mealBtn" text="MEAL BREAK" 
                           style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 24; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(245, 158, 11, 0.3), 10, 0, 0, 4);"/>
                </HBox>
                <Label text="Today: 7h 23m" 
                       style="-fx-text-fill: #475569; -fx-font-size: 14px; -fx-font-weight: 600; -fx-background-color: #f1f5f9; -fx-padding: 8 16; -fx-background-radius: 20;"/>
            </VBox>

            <!-- Recent Entries Card -->
            <VBox spacing="16" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5);" maxWidth="800">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Recent Time Entries" 
                           style="-fx-text-fill: #1e293b; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="VIEW ALL" 
                           style="-fx-background-color: transparent; -fx-text-fill: #3b82f6; -fx-font-weight: 600; -fx-underline: true; -fx-cursor: hand;"/>
                </HBox>
                <TableView fx:id="timeTable" prefHeight="220" 
                          style="-fx-background-color: transparent; -fx-border-color: #e2e8f0; -fx-border-radius: 8;">
                    <columns>
                        <TableColumn fx:id="colDate" text="DATE" 
                                   style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TableColumn fx:id="colAction" text="ACTION" 
                                   style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TableColumn fx:id="colTime" text="TIME" 
                                   style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TableColumn fx:id="colDuration" text="DURATION" 
                                   style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>

    <!-- ===== BOTTOM FOOTER ===== -->
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #1e293b; -fx-padding: 20;">
            <Label text="© 2025 ClockWise | Time Tracking System | v2.1.0" 
                   style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
        </HBox>
    </bottom>
</BorderPane>